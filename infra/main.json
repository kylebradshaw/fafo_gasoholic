{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "3876370697805914253"
    }
  },
  "parameters": {
    "appName": {
      "type": "string",
      "metadata": {
        "description": "Base name for all resources. Must be globally unique (used for ACR, Key Vault)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    }
  },
  "variables": {
    "acrBase": "[toLower(replace(parameters('appName'), '-', ''))]",
    "acrName": "[format('{0}acr', variables('acrBase'))]",
    "kvName": "[format('{0}-kv', parameters('appName'))]",
    "envName": "[format('{0}-env', parameters('appName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": true
      }
    },
    {
      "type": "Microsoft.Communication/emailServices",
      "apiVersion": "2023-04-01",
      "name": "[format('{0}-acs', parameters('appName'))]",
      "location": "global",
      "properties": {
        "dataLocation": "UnitedStates"
      }
    },
    {
      "type": "Microsoft.Communication/emailServices/domains",
      "apiVersion": "2023-04-01",
      "name": "[format('{0}/{1}', format('{0}-acs', parameters('appName')), 'AzureManagedDomain')]",
      "location": "global",
      "properties": {
        "domainManagement": "AzureManaged"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Communication/emailServices', format('{0}-acs', parameters('appName')))]"
      ]
    },
    {
      "type": "Microsoft.Communication/communicationServices",
      "apiVersion": "2023-04-01",
      "name": "[format('{0}-comms', parameters('appName'))]",
      "location": "global",
      "properties": {
        "dataLocation": "UnitedStates",
        "linkedDomains": [
          "[resourceId('Microsoft.Communication/emailServices/domains', format('{0}-acs', parameters('appName')), 'AzureManagedDomain')]"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Communication/emailServices/domains', format('{0}-acs', parameters('appName')), 'AzureManagedDomain')]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('kvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'AcsConnection')]",
      "properties": {
        "value": "[listKeys(resourceId('Microsoft.Communication/communicationServices', format('{0}-comms', parameters('appName'))), '2023-04-01').primaryConnectionString]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Communication/communicationServices', format('{0}-comms', parameters('appName')))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'AcsSenderDomain')]",
      "properties": {
        "value": "[reference(resourceId('Microsoft.Communication/emailServices/domains', format('{0}-acs', parameters('appName')), 'AzureManagedDomain'), '2023-04-01').mailFromSenderDomain]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Communication/emailServices/domains', format('{0}-acs', parameters('appName')), 'AzureManagedDomain')]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('envName')]",
      "location": "[parameters('location')]",
      "properties": {}
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "http"
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]",
              "username": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').username]",
              "passwordSecretRef": "acr-password"
            }
          ],
          "secrets": [
            {
              "name": "acr-password",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').passwords[0].value]"
            },
            {
              "name": "acs-connection",
              "keyVaultUrl": "[format('{0}secrets/AcsConnection', reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri)]",
              "identity": "system"
            },
            {
              "name": "acs-sender-domain",
              "keyVaultUrl": "[format('{0}secrets/AcsSenderDomain', reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri)]",
              "identity": "system"
            },
            {
              "name": "sql-connection",
              "keyVaultUrl": "[format('{0}secrets/SqlConnection', reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri)]",
              "identity": "system"
            },
            {
              "name": "smoke-test-secret",
              "keyVaultUrl": "[format('{0}secrets/SmokeTestSecret', reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri)]",
              "identity": "system"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "[parameters('appName')]",
              "image": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
              "env": [
                {
                  "name": "DATABASE_PROVIDER",
                  "value": "sqlserver"
                },
                {
                  "name": "ConnectionStrings__SqlServer",
                  "secretRef": "sql-connection"
                },
                {
                  "name": "ConnectionStrings__ACS",
                  "secretRef": "acs-connection"
                },
                {
                  "name": "AcsSenderDomain",
                  "secretRef": "acs-sender-domain"
                },
                {
                  "name": "CORS_ORIGINS",
                  "value": "[format('https://{0}.{1},https://gas.sdir.cc', parameters('appName'), reference(resourceId('Microsoft.App/managedEnvironments', variables('envName')), '2024-03-01').defaultDomain)]"
                },
                {
                  "name": "SmokeTestSecret",
                  "secretRef": "smoke-test-secret"
                },
                {
                  "name": "ASPNETCORE_ENVIRONMENT",
                  "value": "Production"
                },
                {
                  "name": "ASPNETCORE_URLS",
                  "value": "http://+:8080"
                }
              ],
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 1
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), resourceId('Microsoft.App/containerApps', parameters('appName')), '4633458b-17de-408a-b874-0445c86b69e6')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', parameters('appName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]"
    },
    "acrName": {
      "type": "string",
      "value": "[variables('acrName')]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri]"
    }
  }
}