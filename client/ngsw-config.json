{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": [
          "/assets/**",
          "/**//*"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api",
      "urls": [
        "/api/**",
        "/auth/**"
      ],
      "cacheConfig": {
        "strategy": "network-first",
        "maxAge": "1h",
        "maxSize": 100
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.js",
    "!/**/*.css",
    "!/**/*.*"
  ]
}
